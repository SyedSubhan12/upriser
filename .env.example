# Upriser Environment Variables
# Copy this file to .env and fill in the values

# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Session (required in production)
SESSION_SECRET=generate-a-strong-random-key-here
NODE_ENV=development

# Port
PORT=5000

# Google OAuth (optional — needed for Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# CORS (comma-separated origins)
CLIENT_URL=http://localhost:5173

# Supabase Configuration (required for file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side Supabase (Vite exposes these)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Integration — MCQ Solver + Generator (optional, at least one needed for AI features)
GEMINI_API_KEY=AIzaSyDi_8WHqO3ZDebyGuBNfVJJrxU1ahKWEVo
# OPENAI_API_KEY=your-openai-api-key

# Hardcoded System Users
ADMIN_EMAIL=admin@upriser.com
ADMIN_PASSWORD=admin123
TEACHER_EMAIL=teacher@upriser.com
TEACHER_PASSWORD=teacher123
